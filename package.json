{
  "name": "osmosfeed-multi-channels",
  "version": "1.0.0",
  "description": "Multi-channel RSS Hub",
  "scripts": {
    "build": "concurrently \"npm:build:*\"",
    "build:news": "npm run build --prefix channels/news",
    "build:podcast": "npm run build --prefix channels/podcast",
    "build:video": "npm run build --prefix channels/video",
    "copy": "node copy.mjs"
  },
  "workspaces": [
    "./channels/*"
  ],
  "devDependencies": {
    "@osmoscraft/osmosfeed": "^1.4.0",
    "concurrently": "^6.0.2",
    "fs-extra": "^9.1.0"
  }
}
